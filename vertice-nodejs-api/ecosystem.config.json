{
    "apps": [
        {
            "name": "vertice-pos-api",
            "script": "dist/index.js",
            "cwd": "./",
            "instances": 1,
            "exec_mode": "fork",
            "watch": false,
            "autorestart": true,
            "max_restarts": 10,
            "min_uptime": "10s",
            "max_memory_restart": "500M",
            "env": {
                "NODE_ENV": "production"
            },
            "error_file": "../logs/pm2-error.log",
            "out_file": "../logs/pm2-out.log",
            "log_date_format": "YYYY-MM-DD HH:mm:ss Z",
            "merge_logs": true,
            "kill_timeout": 5000,
            "listen_timeout": 10000,
            "shutdown_with_message": true,
            "wait_ready": false,
            "restart_delay": 4000,
            "exp_backoff_restart_delay": 100,
            "cron_restart": "0 3 * * *"
        }
    ]
}