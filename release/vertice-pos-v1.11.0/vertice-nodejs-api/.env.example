# Vertice POS - Configuración del Backend API
# Copia este archivo a .env y configura los valores

# Base de datos PostgreSQL
DATABASE_URL="postgresql://postgres:admin2425@localhost:5432/vertice_pos_db?schema=public"

# Puerto del servidor API
PORT=3000

# Escuchar en todas las interfaces de red (permite conexiones de otros PCs)
HOST=0.0.0.0

# CORS - Permite conexiones desde cualquier origen
# Cambia a IPs específicas para mayor seguridad: "http://192.168.1.101,http://192.168.1.102"
CORS_ORIGINS=*

# Clave secreta para tokens JWT (cambia esto en producción)
JWT_SECRET=supersecretjwtkey

# Entorno
NODE_ENV=production
